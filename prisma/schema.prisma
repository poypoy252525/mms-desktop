generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  createdAt String
  email     String
  name      String
}

model Death {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  firstName             String
  lastName              String
  dateOfBirth           DateTime
  dateOfDeath           DateTime
  dateCreated           DateTime @default(now())
  causeOfDeath          String
  nextOfKinName         String
  nextOfKinRelationship String
  nextOfKinContact      Int
  status                Status   @default(PRESENT)
  burial                Burial?
}

enum Status {
  PRESENT
  PAST
}

model Burial {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  block       String
  row         String
  plotNumber  String
  coordinates String?
  death       Death   @relation(fields: [deathId], references: [id])
  deathId     String  @unique @db.ObjectId
}
